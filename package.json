    "@kangc/v-md-editor": "^2.3.18",
    "ajv": "^6.11.0",
    "axios": "^0.27.2",
    "clipboard": "2.0.4",
    "codemirror": "^5.49.2",
    "connect": "3.6.6",
    "cron-editor-vue3": "^0.0.13",
    "echarts": "6.0.0",
    "element-plus": "^2.7.0",
    "file-saver": "1.3.8",
    "fuse.js": "3.4.4",
    "highlight.js": "^11.11.1",
