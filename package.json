    "jsencrypt": "^3.3.2",
    "jszip": "^3.7.1",
    "normalize.css": "7.0.0",
    "nprogress": "0.2.0",
    "path-to-regexp": "2.4.0",
    "qs": "^6.9.1",
    "screenfull": "4.2.0",
    "vue": "^3.3.4",
    "vue-count-to": "^1.0.13",
    "vue-cropper": "^1.0.6",
    "vue-highlightjs": "^1.3.3",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.3",
    "vue-ueditor-wrap": "^3.0.8",
    "vue3-count-to": "^1.1.2",
    "vue3-cron-plus": "^0.1.9",
    "vue3-treeselect": "^0.1.10",
